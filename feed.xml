---
layout: null
permalink: /feed.xml
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ site.lang }}">
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ site.url | append: site.baseurl | xml_escape }}" rel="alternate" type="text/html" />
  <id>{{ site.url | append: site.baseurl | xml_escape }}</id>
  <updated>{{ site.posts.first.date | default: site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
    <email>{{ site.author.email | xml_escape }}</email>
    <uri>{{ site.author.github_url | default: site.url | xml_escape }}</uri>
  </author>

  {% for post in site.posts limit:20 %}
    <entry>
      <title>{{ post.title | xml_escape }}</title>
      <link href="{{ post.url | absolute_url }}" rel="alternate" type="text/html" />
      <id>{{ post.url | absolute_url }}</id>
      <published>{{ post.date | date_to_xmlschema }}</published>
      <updated>{{ post.date | date_to_xmlschema }}</updated>
      <summary type="html">{{ post.excerpt | strip_html | xml_escape }}</summary>
      <content type="html">{{ post.content | markdownify | xml_escape }}</content>
      {% for tag in post.tags %}
        <category term="{{ tag | xml_escape }}" />
      {% endfor %}
    </entry>
  {% endfor %}
</feed>
